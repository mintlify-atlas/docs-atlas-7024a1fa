  "keyFeatures": [
    "Cashu ecash wallet with Lightning Network support",
    "Multi-mint management with swap routing and rebalancing",
    "Nostr-based identity, messaging, and social features",
    "NFC tap payments and QR code scanning",
    "Know Your Mint auditing and community ratings",
    "P2PK locking and payment requests (NUT-18)",
    "Transaction filtering and location stamps",
    "Routstr AI integration with multiple models",
    "BTCMap merchant discovery",
    "37 customizable themes",
    "Multi-currency display (USD, EUR, GBP)",
    "BIP-39 seed phrase recovery",
    "4-digit passcode protection"
  ],
  "publicApiSurface": [
    "cashu:// and sovran:// URL schemes for deep linking",
    "Cashu NUT-00 through NUT-13, NUT-17, NUT-18, NUT-23",
    "Lightning BOLT11 invoice support",
    "Nostr NIP-04, NIP-05, NIP-06, NIP-17, NIP-19, NIP-44, NIP-59",
    "NFC NDEF Type 4 Tag protocol",
    "BIP-39 mnemonic generation",
    "BIP-32 hierarchical deterministic key derivation",
    "NIP-06 Nostr key derivation from seed"
  ]
